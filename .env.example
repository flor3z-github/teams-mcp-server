# Azure Bot 자격증명
MICROSOFT_APP_ID=
MICROSOFT_APP_PASSWORD=
MICROSOFT_APP_TENANT_ID=

# Azure App 유형 (SingleTenant / MultiTenant)
MICROSOFT_APP_TYPE=SingleTenant

# MCP Transport (stdio = 채널 모드, http = 도구 서버 모드)
# stdio: Claude Code가 spawn하여 채널로 사용 (기본)
# http: Docker 배포용, /mcp 엔드포인트로 MCP 통신
MCP_TRANSPORT=stdio

# HTTP 서버 포트 (기본: 3978)
TEAMS_PORT=3978

# State 디렉토리 (기본: ~/.claude/channels/teams)
# TEAMS_STATE_DIR=

# 로깅 레벨 (debug|info|warn|error, 기본: info)
LOG_LEVEL=info
