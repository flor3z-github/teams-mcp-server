# HTTP 서버 포트 (기본: 3978)
TEAMS_PORT=3978

# 외부 접근 URL (원격 접속 시 필수, 미지정 시 http://localhost:{port})
# TEAMS_BASE_URL=http://192.168.71.103:3001

# HTTP + 비-localhost URL 사용 시 MCP SDK 검증 우회 (TEAMS_BASE_URL 설정 시 필요)
# MCP_DANGEROUSLY_ALLOW_INSECURE_ISSUER_URL=true

# State 디렉토리 (기본: ~/.claude/channels/teams)
# MSAL 토큰 캐시, OAuth 저장소가 이 디렉토리에 저장됨
# TEAMS_STATE_DIR=

# 로깅 레벨 (debug|info|warn|error, 기본: info)
LOG_LEVEL=info
